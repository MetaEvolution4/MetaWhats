# Configuração Base de Ambiente
# Cópia para .env na raiz ou em /backend

# Banco de Dados PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=metawhats
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metawhats?schema=public"
# NOTA: Quando rodar o backend via Docker Compose, o host será "postgres":
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/metawhats?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_HOST=redis (No docker)

# Backend JWT (Apenas exemplo, altere em produção)
JWT_SECRET="super_secret_jwt_key_12345"
JWT_REFRESH_SECRET="super_secret_jwt_refresh_key_12345"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Configuração de URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3000
SOCKET_URL=http://localhost:3000

# Armazenamento de Arquivos
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# Segurança
CORS_ORIGIN=*
