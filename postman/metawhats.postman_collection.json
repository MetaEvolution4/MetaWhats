{
  "info": {
    "name": "MetaWhats API",
    "description": "Requests base para testar a API do MetaWhats MVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{API_URL}}/health",
          "host": [
            "{{API_URL}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\": \"+5511999999999\"\n}"
            },
            "url": {
              "raw": "{{API_URL}}/api/auth/request-otp",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "request-otp"
              ]
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\": \"+5511999999999\",\n    \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{API_URL}}/api/auth/verify-otp",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-otp"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "API_URL",
      "value": "http://localhost:3000"
    }
  ]
}
